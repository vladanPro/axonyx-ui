page IconButton(variant = "", size = "", surface = "", border = "", type = "button", disabled = "")

<button
  class="ax-button"
  data-variant={variant}
  data-size={size}
  data-surface={surface}
  data-border={border}
  data-icon-only="true"
  type={type}
  data-disabled={disabled}
>
  <Slot />
</button>
