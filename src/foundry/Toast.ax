page Toast(tone = "", title = "")

<div class="ax-toast" data-tone={tone} role="status">
  <div>
    <strong class="ax-toast__title">{title}</strong>
    <p class="ax-toast__description">
      <Slot />
    </p>
  </div>
  <button class="ax-toast__close" type="button" aria-label="Dismiss toast" data-ax-toast-close="true">x</button>
</div>
