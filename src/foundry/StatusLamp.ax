page StatusLamp

<div class="ax-status-lamp" data-tone={tone} data-pulse={pulse}>
  <span class="ax-status-lamp__light"></span>
  <span class="ax-status-lamp__body">
    <span class="ax-status-lamp__label">
      <Slot name="label" />
    </span>
    <span class="ax-status-lamp__description">
      <Slot />
    </span>
  </span>
</div>
