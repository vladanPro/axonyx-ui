page Input(size = "", id = "", name = "", type = "text", value = "", placeholder = "", disabled = "", invalid = "")

<input
  class="ax-input"
  data-size={size}
  id={id}
  name={name}
  type={type}
  value={value}
  placeholder={placeholder}
  data-disabled={disabled}
  data-invalid={invalid}
  aria-invalid={invalid}
/>
